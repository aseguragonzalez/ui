{
  "branches": ["main"],
  "plugins": [
    ["@semantic-release/commit-analyzer", {
      "releaseRules": [
        { "type": "fix", "scope": "deps", "release": false },
        { "type": "fix", "scope": "deps-dev", "release": false },
        { "type": "perf", "scope": "deps", "release": false },
        { "type": "perf", "scope": "deps-dev", "release": false }
      ]
    }],
    "@semantic-release/release-notes-generator",
    ["@semantic-release/changelog", {
      "changelogFile": "CHANGELOG.md"
    }],
    ["@semantic-release/npm", { "npmPublish": false }],
    ["@semantic-release/exec", {
      "publishCmd": "npm config delete //registry.npmjs.org/:_authToken && npm publish --provenance --access public"
    }],
    ["@semantic-release/git", {
      "assets": ["CHANGELOG.md", "package.json"],
      "message": "chore: release ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
    }],
    "@semantic-release/github"
  ]
}
