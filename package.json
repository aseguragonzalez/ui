{
  "name": "@aseguragonzalez/ui",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "description": "Accessible, themeable design system for React SPAs",
  "keywords": [
    "react",
    "design-system",
    "ui",
    "components",
    "accessible",
    "wcag",
    "typescript",
    "css-custom-properties",
    "theming"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aseguragonzalez/ui.git"
  },
  "homepage": "https://github.com/aseguragonzalez/ui#readme",
  "bugs": {
    "url": "https://github.com/aseguragonzalez/ui/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens.css": "./dist/tokens.css",
    "./index.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "storybook dev -p 6006 --no-open",
    "build": "npm run types:css && tsc -b && vite build",
    "build:storybook": "storybook build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:storybook": "vitest run --project storybook",
    "test:all": "vitest run",
    "test:coverage": "vitest run --project unit --coverage",
    "types:css": "tcm src",
    "types:css:watch": "tcm src --watch",
    "release": "semantic-release"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.5",
    "globals": "^17.5.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.0",
    "playwright": "^1.59.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "storybook": "^10.3.5",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "semantic-release": "^24.0.0",
    "typed-css-modules": "^0.9.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
